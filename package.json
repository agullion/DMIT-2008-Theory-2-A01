{
  "name": "theory-2-jan-2026",
  "version": "0.2.1",
  "private": true,
  "scripts": {
    "predev": "pnpm unocss:build",
    "dev": "concurrently \"pnpm unocss:watch\" \"next dev\"",
    "prebuild": "pnpm unocss:build",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "unocss:build": "unocss \"src/**/*.{js,jsx,ts,tsx}\" --config unocss.config.js -o src/styles/unocss.css",
    "unocss:watch": "unocss \"src/**/*.{js,jsx,ts,tsx}\" --config unocss.config.js -w -o src/styles/unocss.css",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.1",
    "dayjs": "1.11.19",
    "jsdom": "^29.0.2",
    "msw": "^2.13.4",
    "next": "^16.2.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "5.5.0",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "devDependencies": {
    "@unocss/cli": "^66.6.2",
    "@unocss/postcss": "^66.6.2",
    "@unocss/preset-uno": "^66.6.2",
    "@unocss/reset": "^66.6.2",
    "@unocss/webpack": "^66.6.2",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "unocss": "^66.6.2"
  }
}
